@page
@model eCertify.Pages.Certificacion.CommercialApprovalModel

<!-- ── Step hero header ── -->
<div class="step-hero">
    <div class="sh-content">
        <div class="sh-badge">
            <i class="bi bi-patch-check-fill"></i>
            Certificación e-CF
        </div>
        <h5 class="sh-title">Aprobación Comercial</h5>
    </div>
    <div class="sh-actions">
        <a href="/Home" class="sh-btn">
            <i class="bi bi-house-door"></i> Inicio
        </a>
        <button type="button" class="sh-btn" data-bs-toggle="offcanvas" data-bs-target="#caHelp">
            <i class="bi bi-question-circle"></i> Ayuda
        </button>
        <form method="post" asp-page-handler="MarkCompleted"
              id="formCompletado" class="form-completado"
              data-completado="@Model.StepCompleted.ToString().ToLower()"
              style="margin:0">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="sh-btn sh-btn--complete btn-completado @(Model.StepCompleted ? "is-done" : "")">
                <i class="@(Model.StepCompleted ? "fas" : "far") fa-check-circle"></i>
                @(Model.StepCompleted ? "¡Completado!" : "Marcar Completado")
            </button>
        </form>
    </div>
</div>

<!-- ── Help offcanvas ── -->
<div class="offcanvas offcanvas-end help-offcanvas" tabindex="-1" id="caHelp" aria-labelledby="caHelpLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="caHelpLabel">
            <i class="bi bi-info-circle me-2"></i>Guía — Aprobación Comercial
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
    </div>
    <div class="offcanvas-body">
        <p class="text-muted mb-3">Siga estos pasos para completar la Aprobación Comercial correctamente:</p>
        <ol>
            <li>Desde el portal de la DGII, descargue el archivo Excel haciendo clic en <strong>Descargar Aprobaciones Comerciales</strong>, ubicado en la cuadrícula <em>Serie de Datos a Utilizar</em>.</li>
            <li>Haga clic en la zona de carga o arrastre el archivo <strong>.xls / .xlsx</strong> directamente.</li>
            <li>Presione <strong>"Procesar y Enviar"</strong>. El sistema leerá cada fila del Excel, generará el XML correspondiente y lo enviará automáticamente a la DGII.</li>
            <li>Observe el <strong>Log de Envío</strong> en tiempo real. Cada aprobación mostrará el resultado (<em>Aceptada / Rechazada</em>) junto con la respuesta completa de la DGII.</li>
            <li>Cuando todas las aprobaciones hayan sido aceptadas, presione <strong>Marcar Completado</strong> para registrar el paso.</li>
        </ol>
        <div class="alert alert-warning mt-3 mb-0" role="alert">
            <strong>Importante:</strong> Si alguna aprobación es rechazada, la DGII reinicia el conteo a cero. Deberá refrescar la página y volver a subir el archivo desde el principio.
        </div>
    </div>
</div>

<!-- ── Processing overlay ── -->
<div id="processingOverlay" style="display:none;">
    <div class="overlay-box">
        <div class="spinner-border text-success" role="status" style="width:2.5rem;height:2.5rem;"></div>
        <p id="overlayMessage" class="mt-3 mb-0">Procesando archivo...</p>
    </div>
</div>

<!-- ── Main card ── -->
<div class="card p-4 mb-4 shadow-sm">
    <div class="row g-4">

        <!-- Left: file uploader -->
        <div class="col-lg-5">
            <h5 class="fw-semibold mb-3">Subir archivo Excel</h5>

            <div id="uploadZone">
                <i class="bi bi-cloud-arrow-up fs-1 text-secondary"></i>
                <p class="mb-1 mt-2 fw-semibold">Haga clic o arrastre un archivo aquí</p>
                <p class="mb-0 text-muted small">Formatos aceptados: .xls / .xlsx</p>
                <input type="file" id="fileInput" accept=".xlsx,.xls"
                       class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                       style="cursor:pointer;" />
                <div id="selectedFileName" class="mt-2 fw-bold text-success small"></div>
            </div>

            <button class="btn btn-success mt-3 w-100" id="uploadBtn" onclick="initProcessAndSend()">
                <span class="spinner-border spinner-border-sm d-none me-1" id="btnSpinner" role="status"></span>
                <i class="bi bi-send me-2" id="btnIcon"></i>
                <span id="btnLabel">Procesar y Enviar</span>
            </button>
        </div>

        <!-- Right: send log -->
        <div class="col-lg-7">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <h5 class="fw-semibold mb-0">Log de Envío</h5>
                <button class="btn btn-sm btn-outline-secondary" onclick="clearLog()" title="Limpiar log">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
            <div id="sendLog"></div>
        </div>

    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-success text-white">
                <strong class="me-auto">Éxito</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["SuccessMessage"]</div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-danger text-white">
                <strong class="me-auto">Error</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["ErrorMessage"]</div>
        </div>
    </div>
}

@section Scripts {
<script src="~/js/PasosCompletados.js"></script>
<script>
    // ── UI state helpers ──────────────────────────────────────────────
    function setProcessingState(active, message = 'Procesando...') {
        const overlay   = document.getElementById('processingOverlay');
        const btn       = document.getElementById('uploadBtn');
        const spinner   = document.getElementById('btnSpinner');
        const icon      = document.getElementById('btnIcon');
        const label     = document.getElementById('btnLabel');
        const fileInput = document.getElementById('fileInput');

        overlay.style.display = active ? 'flex' : 'none';
        document.getElementById('overlayMessage').textContent = message;
        btn.disabled       = active;
        fileInput.disabled = active;
        spinner.classList.toggle('d-none', !active);
        icon.classList.toggle('d-none', active);
        label.textContent = active ? 'Procesando...' : 'Procesar y Enviar';
    }

    function clearLog() {
        document.getElementById('sendLog').innerHTML = '';
    }

    // ── Log helpers ───────────────────────────────────────────────────
    function logEntry(type, fileName, message) {
        const log  = document.getElementById('sendLog');
        const time = new Date().toLocaleTimeString('es-DO');
        const icons = { info: '●', success: '✔', error: '✖', warning: '⚠' };
        const icon  = icons[type] || '●';

        const entry = document.createElement('div');
        entry.className = `log-entry log-entry--${type}`;
        entry.innerHTML = `
            <div class="log-entry__header">
                <span class="log-entry__time">[${time}]</span>
                ${fileName ? `<span class="log-entry__file">${fileName}</span>` : ''}
                <span class="log-entry__msg">${icon} ${message}</span>
            </div>`;
        log.appendChild(entry);
        log.scrollTop = log.scrollHeight;
    }

    const logInfo    = (f, m) => logEntry('info',    f, m);
    const logSuccess = (f, m) => logEntry('success', f, m);
    const logError   = (f, m) => logEntry('error',   f, m);
    const logWarning = (f, m) => logEntry('warning', f, m);

    // ── Formatting ────────────────────────────────────────────────────
    function formatApprovalResponse(encf, result) {
        const json = JSON.stringify(result, null, 2);
        return `Aprobación <strong>${encf}</strong> procesada. Respuesta de la DGII:`
            + `<pre style="margin:6px 0 0;padding:8px 10px;background:rgba(0,0,0,0.3);`
            + `border-radius:4px;font-size:0.74rem;white-space:pre-wrap;word-break:break-all;`
            + `color:#c9d1d9;max-height:180px;overflow-y:auto;">${escapeHtml(json)}</pre>`;
    }

    function escapeHtml(str) {
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    }

    // ── API calls ─────────────────────────────────────────────────────
    async function loadExcelRows(file) {
        const formData = new FormData();
        formData.append('ExcelFile', file);

        const res = await fetch('?handler=LoadExcel', {
            method: 'POST',
            headers: { 'RequestVerificationToken': getAntiForgeryToken() },
            body: formData
        });

        if (!res.ok) {
            const err = await res.text();
            throw new Error(err || 'Error al procesar el archivo Excel');
        }
        return await res.json();
    }

    async function sendRow(row) {
        const res = await fetch('?handler=SendRow', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getAntiForgeryToken()
            },
            body: JSON.stringify(row)
        });

        const rawText = await res.text();
        try {
            return JSON.parse(rawText);
        } catch {
            throw new Error(`Respuesta inesperada del servidor: ${rawText.substring(0, 120)}`);
        }
    }

    // ── Main orchestrator ─────────────────────────────────────────────
    async function initProcessAndSend() {
        const file = document.getElementById('fileInput').files[0];
        if (!file) {
            alert('Debe seleccionar un archivo Excel antes de continuar.');
            return;
        }

        clearLog();
        setProcessingState(true, 'Cargando archivo Excel...');
        logInfo(null, 'Iniciando carga del archivo Excel...');

        try {
            // Step 1: parse Excel rows
            const rows = await loadExcelRows(file);

            if (!rows.length) {
                logWarning(null, 'No se encontraron registros en el archivo. Verifique el contenido.');
                return;
            }

            logSuccess(null, `Archivo procesado. ${rows.length} aprobación(es) encontrada(s). Iniciando envío...`);

            // Step 2: send each row sequentially
            for (const row of rows) {
                const encf = row.encf || `Fila ${row.rowNumber}`;
                setProcessingState(true, `Enviando ${encf}...`);
                logInfo(encf, 'Enviando a la DGII...');

                try {
                    const result = await sendRow(row);
                    const msg = formatApprovalResponse(encf, result);

                    if (result.success && result.estado === 1) {
                        logSuccess(encf, msg);
                    } else {
                        logError(encf, msg);
                    }
                } catch (err) {
                    logError(encf, `Error al enviar: ${err.message}`);
                }

                await delay(300);
            }

            logSuccess(null, '¡Proceso completado! Revise el log para verificar el estado de cada aprobación.');

        } catch (err) {
            logError(null, `Error durante el proceso: ${err.message}`);
        } finally {
            setProcessingState(false);
        }
    }

    // ── File zone setup ───────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        const zone      = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');
        const fileLabel = document.getElementById('selectedFileName');

        fileInput.addEventListener('change', () => {
            const file = fileInput.files[0];
            if (!file) { fileLabel.textContent = ''; return; }

            const valid = /\.(xlsx|xls)$/i.test(file.name);
            if (!valid) {
                fileLabel.textContent = 'Archivo no válido. Solo .xlsx o .xls';
                fileLabel.classList.replace('text-success', 'text-danger');
                fileInput.value = '';
                return;
            }
            fileLabel.textContent = file.name;
            fileLabel.classList.replace('text-danger', 'text-success');
        });

        zone.addEventListener('dragover',  e => { e.preventDefault(); zone.classList.add('drag-over'); });
        zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
        zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            if (e.dataTransfer.files.length) {
                fileInput.files = e.dataTransfer.files;
                fileInput.dispatchEvent(new Event('change'));
            }
        });
    });
</script>
}
