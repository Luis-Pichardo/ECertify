@page
@model eCertify.Pages.Certificacion.PruebasModel

@inject IConfiguration Configuration

<link rel="stylesheet" href="~/css/Pruebas.css" asp-append-version="true" />

<div class="step-hero">
    <div class="sh-content">
        <div class="sh-badge">
            <i class="bi bi-clipboard-check"></i>
            Certificación e-CF
        </div>
        <h5 class="sh-title">Prueba de Datos e-CF</h5>
    </div>
    <div class="sh-actions">
        <a href="/Home" class="sh-btn">
            <i class="bi bi-house-door"></i> Inicio
        </a>
        <button type="button" class="sh-btn" data-bs-toggle="offcanvas" data-bs-target="#pruebasHelp">
            <i class="bi bi-question-circle"></i> Ayuda
        </button>
        <form method="post" asp-page-handler="MarcarCompletado"
              id="formCompletado" class="form-completado"
              data-completado="@Model.StepCompleted.ToString().ToLower()"
              style="margin:0">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="sh-btn sh-btn--complete btn-completado @(Model.StepCompleted ? "is-done" : "")">
                <i class="@(Model.StepCompleted ? "fas" : "far") fa-check-circle"></i>
                @(Model.StepCompleted ? "¡Completado!" : "Marcar Completado")
            </button>
        </form>
    </div>
</div>

<!-- Help offcanvas -->
<div class="offcanvas offcanvas-end help-offcanvas" tabindex="-1" id="pruebasHelp"
     aria-labelledby="pruebasHelpLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="pruebasHelpLabel">
            <i class="bi bi-info-circle me-2"></i>Guía — Pruebas de Datos e-CF
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
    </div>
    <div class="offcanvas-body">
        <p class="text-muted mb-3">Siga estos pasos para completar el proceso de pruebas correctamente:</p>
        <ol>
            <li>Descargue el archivo Excel de pruebas desde el portal de la DGII y guárdelo en su computadora.</li>
            <li>Haga clic en la zona de carga o arrastre el archivo <strong>.xls / .xlsx</strong> directamente.</li>
            <li>Presione <strong>"Procesar y Enviar"</strong>. El sistema generará los XMLs y los enviará automáticamente a la DGII en el orden correcto.</li>
            <li>Observe el <strong>Log de Envío</strong> en tiempo real. Cada comprobante mostrará su resultado (Aceptado / Rechazado) junto con botones para <strong>Ver</strong> el XML o <strong>Descargar</strong> el archivo.</li>
            <li>Las facturas de tipo <strong>E32 con monto menor a RD$250,000</strong> se envían a la DGII como <strong>Resumen (RFCE)</strong> y adicionalmente se descargan automáticamente. Debe subir esos archivos XML manualmente al portal de la DGII.</li>
            <li>Los comprobantes <strong>E33 y E34</strong> se envían al final del proceso de forma automática.</li>
        </ol>
        <div class="alert alert-warning mt-3 mb-0" role="alert">
            <strong>Importante:</strong> Si algún comprobante es rechazado, la DGII reinicia el conteo a cero. Deberá refrescar la página y volver a subir el archivo Excel desde el principio.
        </div>
    </div>
</div>

<!-- Processing overlay -->
<div id="processingOverlay" style="display:none;">
    <div class="overlay-box">
        <div class="spinner-border text-success" role="status" style="width:2.5rem;height:2.5rem;"></div>
        <p id="overlayMessage" class="mt-3 mb-0">Procesando archivo...</p>
    </div>
</div>

<!-- XML viewer modal -->
<div class="modal fade" id="xmlViewerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="xmlViewerTitle">Contenido XML</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <pre id="xmlViewerContent"
                     style="background:#0d1117;color:#c9d1d9;margin:0;padding:1.25rem;
                            font-size:0.8rem;white-space:pre-wrap;word-break:break-all;
                            max-height:70vh;overflow-y:auto;border-radius:0 0 4px 4px;"></pre>
            </div>
        </div>
    </div>
</div>

<div class="card p-4 mb-4 shadow-sm">
    <div class="row g-4">

        <!-- LEFT: File uploader -->
        <div class="col-lg-5">
            <h5 class="fw-semibold mb-3">Subir archivo Excel</h5>

            <div id="uploadZone">
                <i class="bi bi-cloud-arrow-up fs-1 text-secondary"></i>
                <p class="mb-1 mt-2 fw-semibold">Haga clic o arrastre un archivo aquí</p>
                <p class="mb-0 text-muted small">Formatos aceptados: .xls / .xlsx</p>
                <input type="file" id="fileInput" accept=".xlsx,.xls"
                       class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                       style="cursor:pointer;" />
                <div id="fileName" class="mt-2 fw-bold text-success small"></div>
            </div>

            <button class="btn btn-success mt-3 w-100" id="uploadBtn" onclick="initProcessAndSend()">
                <span class="spinner-border spinner-border-sm d-none me-1" id="btnSpinner" role="status"></span>
                <i class="bi bi-send me-2" id="btnIcon"></i>
                <span id="btnLabel">Procesar y Enviar</span>
            </button>
        </div>

        <!-- RIGHT: Send log -->
        <div class="col-lg-7">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <h5 class="fw-semibold mb-0">Log de Envío</h5>
                <button class="btn btn-sm btn-outline-secondary" onclick="clearLog()" title="Limpiar log">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
            <div id="sendLog"></div>
        </div>

    </div>
</div>


@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-success text-white">
                <strong class="me-auto">Éxito</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["SuccessMessage"]</div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-danger text-white">
                <strong class="me-auto">Error</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["ErrorMessage"]</div>
        </div>
    </div>
}

@section Scripts {
<script src="~/js/PasosCompletados.js"></script>
<script>
    const apiBaseUrl = '@Configuration["ApiUrl"]';
    const authToken  = '@User.FindFirst("Token")?.Value';
    const userRnc    = '@User.FindFirst("RNC")?.Value';

    // E33/E34 are sent via API but always last
    const SEND_LAST_TYPES = ['E33', 'E34'];

    window.pasoCompletado = @Json.Serialize(Model.StepCompleted);

    // ── UI state helpers ──────────────────────────────────────────

    function setProcessingState(active, message = 'Procesando...') {
        const overlay  = document.getElementById('processingOverlay');
        const btn      = document.getElementById('uploadBtn');
        const spinner  = document.getElementById('btnSpinner');
        const icon     = document.getElementById('btnIcon');
        const label    = document.getElementById('btnLabel');
        const fileInput = document.getElementById('fileInput');

        overlay.style.display = active ? 'flex' : 'none';
        document.getElementById('overlayMessage').textContent = message;

        btn.disabled = active;
        fileInput.disabled = active;
        spinner.classList.toggle('d-none', !active);
        icon.classList.toggle('d-none', active);
        label.textContent = active ? 'Procesando...' : 'Procesar y Enviar';
    }

    function clearLog() {
        document.getElementById('sendLog').innerHTML = '';
    }

    // ── Log helpers ───────────────────────────────────────────────

    function logEntry(type, fileName, message, fileNameFull = null) {
        const log = document.getElementById('sendLog');
        const time = new Date().toLocaleTimeString('es-DO');

        const entry = document.createElement('div');
        entry.className = `log-entry log-entry--${type}`;
        entry.dataset.file = fileNameFull || '';

        const typeIcons = { info: '●', success: '✔', error: '✖', warning: '⚠', download: '↓' };
        const icon = typeIcons[type] || '●';

        entry.innerHTML = `
            <div class="log-entry__header">
                <span class="log-entry__time">[${time}]</span>
                ${fileName ? `<span class="log-entry__file">${fileName}</span>` : ''}
                <span class="log-entry__msg">${icon} ${message}</span>
            </div>
            ${fileNameFull ? `
            <div class="log-entry__actions">
                <button class="log-btn log-btn--view" onclick="viewXml('${fileNameFull}', this)">
                    <i class="bi bi-eye me-1"></i>Ver
                </button>
                <button class="log-btn log-btn--download" onclick="downloadXml('${fileNameFull}')">
                    <i class="bi bi-download me-1"></i>Descargar
                </button>
            </div>
            <div class="log-entry__xml-preview"></div>` : ''}
        `;

        log.appendChild(entry);
        log.scrollTop = log.scrollHeight;
    }

    function logInfo(fileName, message, fileNameFull = null) {
        logEntry('info', fileName, message, fileNameFull);
    }

    function logSuccess(fileName, message, fileNameFull = null) {
        logEntry('success', fileName, message, fileNameFull);
    }

    function logError(fileName, message, fileNameFull = null) {
        logEntry('error', fileName, message, fileNameFull);
    }

    function logWarning(fileName, message, fileNameFull = null) {
        logEntry('warning', fileName, message, fileNameFull);
    }

    function logDownload(fileName, message, fileNameFull) {
        logEntry('download', fileName, message, fileNameFull);
    }

    // ── XML viewer ────────────────────────────────────────────────

    async function viewXml(fileNameFull, btn) {
        const entry = btn.closest('.log-entry');
        const preview = entry.querySelector('.log-entry__xml-preview');

        if (preview.style.display === 'block') {
            preview.style.display = 'none';
            return;
        }

        if (preview.dataset.loaded) {
            preview.style.display = 'block';
            return;
        }

        try {
            const res = await fetch(
                `${apiBaseUrl}api/PruebasExcel/VerContenidoXml?rnc=${encodeURIComponent(userRnc)}&fileName=${encodeURIComponent(fileNameFull)}`,
                { headers: { Authorization: `Bearer ${authToken}` } }
            );
            const data = await res.json();
            if (!data.success) throw new Error(data.message);

            preview.textContent = data.content;
            preview.dataset.loaded = 'true';
            preview.style.display = 'block';
        } catch (err) {
            preview.textContent = 'No se pudo cargar el contenido del XML.';
            preview.style.display = 'block';
        }
    }

    // ── Download helpers ──────────────────────────────────────────

    async function downloadXml(fileNameFull) {
        const url = `${apiBaseUrl}api/PruebasExcel/DescargarXmlGeneral?rnc=${encodeURIComponent(userRnc)}&fileName=${encodeURIComponent(fileNameFull)}`;
        try {
            const res = await fetch(url, { headers: { Authorization: `Bearer ${authToken}` } });
            if (!res.ok) throw new Error('Error al obtener el archivo');
            const blob = await res.blob();
            triggerBrowserDownload(blob, fileNameFull);
        } catch (err) {
            logError(fileNameFull, `No se pudo descargar: ${err.message}`);
        }
    }

    function triggerBrowserDownload(blob, fileName) {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(a.href);
    }

    // ── ECF type detection ────────────────────────────────────────

    // ECF type codes are always E + exactly 2 digits (E31, E32, E33…E47)
    function getEcfPrefix(fileName) {
        const match = fileName.match(/E(\d{2})\d/i);
        return match ? `E${match[1]}`.toUpperCase() : '';
    }

    function isSendLast(fileName) {
        return SEND_LAST_TYPES.includes(getEcfPrefix(fileName));
    }

    // ── API calls ─────────────────────────────────────────────────

    async function processExcelFile(file) {
        const formData = new FormData();
        formData.append('RNC', userRnc);
        formData.append('ExcelFile', file);

        const res = await fetch(`${apiBaseUrl}api/PruebasExcel/GenerarXmlsExcel`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${authToken}` },
            body: formData
        });

        if (!res.ok) {
            const errText = await res.text();
            throw new Error(errText || 'Error al procesar el archivo Excel');
        }
    }

    async function fetchGeneratedFiles() {
        const res = await fetch(
            `${apiBaseUrl}api/PruebasExcel/ListarXmlsGenerados?rnc=${encodeURIComponent(userRnc)}`,
            { headers: { Authorization: `Bearer ${authToken}` } }
        );
        if (!res.ok) throw new Error('No se pudo obtener la lista de archivos generados');
        const data = await res.json();
        return data.archivos || [];
    }

    async function sendXmlFile(fileNameStripped) {
        const formData = new FormData();
        formData.append('rnc', userRnc);
        formData.append('fileName', fileNameStripped);

        const res = await fetch(`${apiBaseUrl}api/PruebasExcel/EnviarXmlSegunTipo`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${authToken}` },
            body: formData
        });

        const rawText = await res.text();
        let result;
        try {
            result = JSON.parse(rawText);
        } catch {
            throw new Error(`Respuesta inesperada del servidor: ${rawText.substring(0, 120)}`);
        }

        // Normalize nested response
        let status = result?.datosFactura?.estado ?? result?.estado ?? null;
        if (!status && typeof result.message === 'string') {
            try {
                const inner = JSON.parse(result.message);
                status = inner?.estado ?? 'No Enviado';
                result.datosFactura = inner;
            } catch {
                status = 'No Enviado';
            }
        }

        return { result, status };
    }

    async function recordSendHistory(fileNameFull, displayName, result, status) {
        const ecfPrefix = getEcfPrefix(displayName);
        await fetch(`${apiBaseUrl}api/HistorialPruebasExcel/Registrar`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                Authorization: `Bearer ${authToken}`
            },
            body: JSON.stringify({
                rnc:              result.datosFactura?.rnc ?? userRnc,
                encf:             result.datosFactura?.encf ?? fileNameFull,
                tipo:             ecfPrefix === 'E32' ? 'RFCE' : 'ECF',
                estadoEnvio:      status,
                codigoRespuesta:  result.datosFactura?.codigo ?? '',
                trackId:          result.datosFactura?.trackId ?? '',
                mensajes:         JSON.stringify(result.datosFactura?.mensajes ?? []),
                archivoXml:       fileNameFull,
                secuenciaUtilizada: result.datosFactura?.secuenciaUtilizada ?? false,
                fechaEnvio:       new Date().toISOString()
            })
        });
    }

    // ── Main orchestrator ─────────────────────────────────────────

    async function initProcessAndSend() {
        const file = document.getElementById('fileInput').files[0];
        if (!file) {
            alert('Debe seleccionar un archivo Excel antes de continuar.');
            return;
        }

        clearLog();
        setProcessingState(true, 'Procesando archivo Excel...');
        logInfo(null, 'Iniciando procesamiento del archivo Excel...');

        try {
            // Step 1: upload & generate XMLs
            await processExcelFile(file);
            logSuccess(null, 'Archivo procesado correctamente. Obteniendo comprobantes generados...');

            // Step 2: get file list
            const files = await fetchGeneratedFiles();
            if (!files.length) {
                logWarning(null, 'No se encontraron comprobantes generados. Verifique el archivo Excel.');
                return;
            }

            // Normalize: remove RNC prefix for display
            const normalizedFiles = files.map(f => {
                let displayName = f.nombreArchivo;
                if (displayName.startsWith(userRnc)) {
                    displayName = displayName.slice(userRnc.length);
                }
                return {
                    fileNameFull: f.nombreArchivo,
                    displayName,
                    puedeDescargarse: f.puedeDescargarse
                };
            });

            // E32 < 250K: sent as RFCE via API AND also force-downloaded (original invoice XML)
            // Double-check: backend flag AND filename must be E32 — prevents any wrong download
            const forcedDownloadFiles = normalizedFiles.filter(f =>
                f.puedeDescargarse && getEcfPrefix(f.displayName) === 'E32'
            );
            const sendLastFiles       = normalizedFiles.filter(f => isSendLast(f.displayName));
            const sendFirstFiles      = normalizedFiles.filter(f => !isSendLast(f.displayName));

            logInfo(null,
                `${normalizedFiles.length} comprobante(s) generado(s). ` +
                `Orden de envío: ${sendFirstFiles.length} primero(s) → ` +
                `${sendLastFiles.length} al final (E33/E34). ` +
                `${forcedDownloadFiles.length} factura(s) E32 se descargarán al finalizar.`
            );

            // Step 3: send first batch (includes E32 < 250K sent as RFCE)
            for (const f of sendFirstFiles) {
                await sendAndLog(f);
            }

            // Step 4: send E33/E34 last
            if (sendLastFiles.length) {
                logInfo(null, 'Enviando comprobantes E33/E34 (al final según requisito DGII)...');
                for (const f of sendLastFiles) {
                    await sendAndLog(f);
                }
            }

            // Step 5: force-download the original E32 invoice XMLs (< 250K)
            // These were sent as RFCE but the user must also upload the originals to DGII portal
            if (forcedDownloadFiles.length) {
                logInfo(null,
                    `Descargando ${forcedDownloadFiles.length} factura(s) E32 — ` +
                    `deben subirse manualmente al portal de la DGII.`
                );
                for (const f of forcedDownloadFiles) {
                    setProcessingState(true, `Descargando factura ${f.displayName}...`);
                    logDownload(
                        f.displayName,
                        '<span class="badge-forced">DESCARGA OBLIGATORIA</span> Factura E32 enviada como RFCE. Suba este XML manualmente al portal DGII.',
                        f.fileNameFull
                    );
                    await downloadXml(f.fileNameFull);
                    await delay(500);
                }
            }

            logSuccess(null, '¡Proceso completado! Revise el log para verificar el estado de cada comprobante.');

        } catch (err) {
            logError(null, `Error durante el proceso: ${err.message}`);
        } finally {
            setProcessingState(false);
        }
    }

    function formatDgiiResponse(ncf, result) {
        const json = JSON.stringify(result, null, 2);
        return `Comprobante <strong>${ncf}</strong> enviado a la DGII. La respuesta de la DGII es la siguiente:`
            + `<pre style="margin:6px 0 0;padding:8px 10px;background:rgba(0,0,0,0.3);`
            + `border-radius:4px;font-size:0.74rem;white-space:pre-wrap;word-break:break-all;`
            + `color:#c9d1d9;max-height:180px;overflow-y:auto;">${escapeHtml(json)}</pre>`;
    }

    function escapeHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    async function sendAndLog(fileInfo) {
        setProcessingState(true, `Enviando ${fileInfo.displayName}...`);
        logInfo(fileInfo.displayName, 'Enviando a la DGII...');

        try {
            const { result, status } = await sendXmlFile(fileInfo.displayName);
            const ncf  = fileInfo.displayName.replace(/\.xml$/i, '');
            const norm = (status ?? '').toLowerCase();
            const msg  = formatDgiiResponse(ncf, result);

            if (norm.includes('aceptado')) {
                logSuccess(fileInfo.displayName, msg, fileInfo.fileNameFull);
            } else if (norm.includes('rechazado')) {
                logError(fileInfo.displayName, msg, fileInfo.fileNameFull);
            } else {
                logInfo(fileInfo.displayName, msg, fileInfo.fileNameFull);
            }

            await recordSendHistory(fileInfo.fileNameFull, fileInfo.displayName, result, status);
        } catch (err) {
            logError(fileInfo.displayName, `Error al enviar: ${err.message}`, fileInfo.fileNameFull);
        }

        await delay(300);
    }

    function delay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    // ── File zone setup ───────────────────────────────────────────

    document.addEventListener('DOMContentLoaded', () => {
        const zone      = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');
        const fileLabel = document.getElementById('fileName');

        fileInput.addEventListener('change', () => {
            const file = fileInput.files[0];
            if (!file) { fileLabel.textContent = ''; return; }

            const valid = file.name.toLowerCase().endsWith('.xlsx') || file.name.toLowerCase().endsWith('.xls');
            if (!valid) {
                fileLabel.textContent = 'Archivo no válido. Solo .xlsx o .xls';
                fileLabel.classList.replace('text-success', 'text-danger');
                fileInput.value = '';
                return;
            }
            fileLabel.textContent = file.name;
            fileLabel.classList.replace('text-danger', 'text-success');
        });

        zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
        zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
        zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            if (e.dataTransfer.files.length) {
                fileInput.files = e.dataTransfer.files;
                fileInput.dispatchEvent(new Event('change'));
            }
        });
    });
</script>
}
