@page "{rnc}"
@model eCertify.Pages.ConsultarFacturasModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Consultar Facturas</title>
    <link rel="icon" href="~/assets/favicon.PNG" type="image/x-icon" />
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <!-- Estilos personalizados -->
    <link rel="stylesheet" href="~/css/ConsultarFacturas.css" />
</head>
<body class="p-4 bg-light">

    <div class="card p-4 mb-4 shadow-sm">
        <h2 class="pb-2">Consultar Facturas</h2>
        <form method="get">
            <div class="card p-4 mb-4 shadow-sm">
                <!-- Primera fila: Búsqueda + Fechas -->
                <div class="row gy-2 gx-3 align-items-center mb-2">
                    <div class="col-auto">
                        <label for="fechaInicio" class="col-form-label fw-bold">Desde:</label>
                    </div>
                    <div class="col-md-2">
                        <input id="fechaInicio" type="date" name="fechaInicio"
                               value="@(string.IsNullOrEmpty(Request.Query["fechaInicio"]) ? DateTime.Now.ToString("yyyy-MM-dd") : Request.Query["fechaInicio"].ToString())"
                               class="form-control form-control-sm" />
                    </div>

                    <div class="col-auto">
                        <label for="fechaFin" class="col-form-label fw-bold">Hasta:</label>
                    </div>
                    <div class="col-md-2">
                        <input id="fechaFin" type="date" name="fechaFin"
                               value="@(string.IsNullOrEmpty(Request.Query["fechaFin"]) ? DateTime.Now.ToString("yyyy-MM-dd") : Request.Query["fechaFin"].ToString())"
                               class="form-control form-control-sm" />
                    </div>

                    <div class="col-auto">
                        <label for="Descripcion" class="col-form-label fw-bold">Descripción:</label>
                    </div>
                    <div class="col">
                        <input id="search" type="text" name="search" value="@Request.Query["search"]"
                               placeholder="No. Comprobante, RNC o Comprador..."
                               class="form-control form-control-sm" />
                    </div>
                </div>

                <!-- Segunda fila: Estado + Tipo + Botón -->
                <div class="row gy-2 gx-3 align-items-center mt-2">
                    <div class="col-auto">
                        <label for="estado" class="col-form-label fw-bold">Estado:</label>
                    </div>
                    <div class="col-md-2">
                        <select id="estado" name="estado" class="form-select form-select-sm">
                            <option value="" selected="@(string.IsNullOrEmpty(Request.Query["estado"]) ? "selected" : null)">Todos</option>
                            <option value="Aceptado" selected="@(Request.Query["estado"] == "Aceptado" ? "selected" : null)">Aceptado</option>
                            <option value="Rechazado" selected="@(Request.Query["estado"] == "Rechazado" ? "selected" : null)">Rechazado</option>
                        </select>
                    </div>

                    <div class="col-auto">
                        <label for="tipo" class="col-form-label fw-bold">Tipo:</label>
                    </div>
                    <div class="col-md-4">
                        <select id="tipo" name="tipo" class="form-select form-select-sm">
                            <option value="" selected="@(string.IsNullOrEmpty(Request.Query["tipo"]) ? "selected" : null)">Todos</option>
                            <option value="31" selected="@(Request.Query["tipo"] == "31" ? "selected" : null)">Factura de Crédito Fiscal</option>
                            <option value="32" selected="@(Request.Query["tipo"] == "32" ? "selected" : null)">Factura de Consumo</option>
                            <option value="33" selected="@(Request.Query["tipo"] == "33" ? "selected" : null)">Nota de Débito</option>
                            <option value="34" selected="@(Request.Query["tipo"] == "34" ? "selected" : null)">Nota de Crédito</option>
                            <option value="41" selected="@(Request.Query["tipo"] == "41" ? "selected" : null)">Comprobante de Compras</option>
                            <option value="43" selected="@(Request.Query["tipo"] == "43" ? "selected" : null)">Gastos Menores</option>
                            <option value="44" selected="@(Request.Query["tipo"] == "44" ? "selected" : null)">Regímenes Especiales</option>
                            <option value="45" selected="@(Request.Query["tipo"] == "45" ? "selected" : null)">Gubernamental</option>
                            <option value="46" selected="@(Request.Query["tipo"] == "46" ? "selected" : null)">Exportaciones</option>
                            <option value="47" selected="@(Request.Query["tipo"] == "47" ? "selected" : null)">Pagos al Exterior</option>
                        </select>
                    </div>

                    <div class="col-auto">
                        <button id="btnBuscar" type="button" class="btn btn-primary btn-sm">Buscar</button>
                    </div>
                </div>
            </div>

            <div class ="card p-4 mb-4 shadow-sm">
                <div>
                    <table id="datos" class="table table-sm table-bordered">
                        <thead class="table-primary">
                            <tr>
                                <th></th>
                                <th>No. Comprobante</th>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th>RNC</th>
                                <th>Estado</th>
                                <th>TrackID</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in Model.Facturas)
                            {
                                <tr data-encf="@f.ENCF">
                                    <td class="text-center align-middle" style="width: 20px; font-weight: bold;">
                                        <button type="button" class="btn btn-sm btn-expand" aria-expanded="false">&gt;</button>
                                    </td>

                                    <td>@f.ENCF</td>
                                    <td>
                                        @{
                                            var fechaFormateada = DateTime.TryParse(f.FechaRecepcion, out var fecha)
                                            ? fecha.ToString("dd/MM/yyyy")
                                            : f.FechaRecepcion;
                                        }
                                        @fechaFormateada
                                    </td>
                                    <td>@f.RazonSocialComprador</td>
                                    <td>@f.RncComprador</td>
                                    <td class="fw-bold">
                                        <span class="px-2 py-1 rounded @(f.Estado == "Aceptado" ? "text-success" : f.Estado == "Rechazado" ? "text-danger" : "text-secondary")">
                                            @f.Estado
                                        </span>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-black ver-trackid-btn bg-warning"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalTrackId"
                                                data-trackid="@f.TrackId">
                                            Ver
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </form>

        <!-- Modal TrackID -->
        <div class="modal fade" id="modalTrackId" tabindex="-1" aria-labelledby="modalTrackIdLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">TrackID</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body">
                        <p id="trackIdModalContent" class="text-monospace"></p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <script>
        const todasLasFacturas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Facturas));
    </script>

    <!-- JQuery + DataTables + Bootstrap JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Script personalizado -->
    <script src="~/js/ConsultarFacturas.js"></script>
</body>
</html>
