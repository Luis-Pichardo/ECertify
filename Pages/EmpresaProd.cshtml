@page
@using System.Text.Json
@model eCertify.Pages.EmpresaProdModel
@{
    Layout = null;
}

@inject IConfiguration Configuration

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrar Empresa</title>
    <link rel="icon" href="~/assets/favicon.PNG" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/EmpresaProd.css" />
    
</head>
<body>
    @if (!Model.AccesoPermitido)
    {
        <div class="acceso-restringido-container">
            <div class="acceso-restringido-card">
                <h4 class="text-center text-primary mb-3">🔒 Acceso Restringido</h4>
                <p class="text-center">Ingrese la clave para continuar:</p>

                <form method="post" asp-page-handler="Clave">
                    <div class="mb-3">
                        <input type="password" name="ClaveUsuario" class="form-control" placeholder="Clave de acceso" required />
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Acceder</button>
                    </div>
                </form>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger mt-3 text-center">@Model.ErrorMessage</div>
                }
            </div>
        </div>
        return;
    }
    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <h2>Registrar Empresa</h2>
                <p>Complete todos los campos requeridos</p>
            </div>

            @* Mensajes de éxito o error *@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    @Model.ErrorMessage
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success">
                    @Model.SuccessMessage
                </div>
            }

            <form method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="row mb-3">
                    <div class="col-md-12">
                        <label asp-for="Empresa.RazonSocial" class="form-label">Razón Social <span class="text-danger">*</span></label>
                        <input asp-for="Empresa.RazonSocial" class="form-control" autofocus required />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Empresa.RNC" class="form-label">RNC <span class="text-danger">*</span></label>
                        <input asp-for="Empresa.RNC" class="form-control" required/>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Empresa.Direccion" class="form-label">Dirección <span class="text-danger">*</span></label>
                        <input asp-for="Empresa.Direccion" class="form-control" required/>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Empresa.Correo" class="form-label">Correo <span class="text-danger">*</span></label>
                        <input asp-for="Empresa.Correo" id="correo" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Empresa.Contrasena" class="form-label">Contraseña <span class="text-danger">*</span></label>
                        <div class="position-relative">
                            <input asp-for="Empresa.Contrasena" type="password" id="contrasena" class="form-control" required />
                            <i class="fas fa-eye password-toggle" data-target="contrasena"></i>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label for="provinciaSelect" class="form-label">Provincia <span class="text-danger">*</span></label>
                        <select id="provinciaSelect" name="Empresa.ProvinciaId" class="form-select" required>
                            <option value="">Seleccione una provincia</option>
                            @foreach (var provincia in Model.ProvinciasConMunicipios)
                            {
                                <option value="@provincia.Id">@provincia.Descripcion</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="municipioSelect" class="form-label">Municipio <span class="text-danger">*</span></label>
                        <select id="municipioSelect" name="Empresa.MunicipioId" class="form-select" disabled required>
                            <option value="">Primero seleccione una provincia</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Certificado Digital (.p12) <span class="text-danger">*</span></label>
                    <div class="file-upload" id="certificadoUpload">
                        <i class="fas fa-cloud-upload-alt fa-3x mb-3" style="color: #6c757d;"></i>
                        <p>Arrastre su archivo aquí o haga clic para seleccionar</p>
                        <p class="text-muted">Formatos aceptados: .p12</p>
                        <input asp-for="Empresa.Certificado" type="file" id="certificado" accept=".p12" required/>
                        <div id="fileNameCertificado" class="mt-2 text-primary fw-bold"></div>
                    </div>
                </div>

                <div class="mb-4 position-relative">
                    <label asp-for="Empresa.CertificadoPass" class="form-label">Contraseña del Certificado <span class="text-danger">*</span></label>
                    <div class="position-relative">
                        <input asp-for="Empresa.CertificadoPass" type="password" class="form-control" id="certificadoPass" required />
                        <i class="fas fa-eye password-toggle" data-target="certificadoPass"></i>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Logo de la Empresa</label>
                    <div class="file-upload" id="logoUpload">
                        <i class="fas fa-cloud-upload-alt fa-3x mb-3" style="color: #6c757d;"></i>
                        <p>Arrastre su archivo aquí o haga clic para seleccionar</p>
                        <p class="text-muted">Formatos aceptados: .png, .jpg, .jpeg</p>
                        <input asp-for="Empresa.LogoArchivo" type="file" id="logoFile" accept=".png,.jpg,.jpeg" />
                        <div id="fileNameLogo" class="mt-2 text-primary fw-bold"></div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-5">
                    <a href="/" class="btn btn-previous btn-custom">
                        <i class="fas fa-arrow-left me-2"></i>Anterior
                    </a>
                    <button id="btnCrearEmpresa" type="submit" class="btn btn-primary btn-custom">
                        <i class="fas fa-save me-2"></i>Crear
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script>
    window.provinciasConMunicipios = @Html.Raw(JsonSerializer.Serialize(Model.ProvinciasConMunicipios, new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    }));
        window.municipioIdInicial = '@Model.Empresa?.MunicipioId';
</script>
    <script src="/js/EmpresaProd.js"></script>
</body>
</html>
