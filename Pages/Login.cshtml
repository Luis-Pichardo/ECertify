@page
@model LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Iniciar Sesión — eCertify</title>
    <link rel="icon" href="~/assets/favicon.PNG" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            overflow: hidden;
            background: linear-gradient(135deg, #004d2b 0%, #006B3C 55%, #008f50 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.08);
            animation: float ease-in-out infinite;
            pointer-events: none;
        }
        .blob-1 { width: 500px; height: 500px; top: -200px; left: -180px; animation-duration: 9s; }
        .blob-2 { width: 380px; height: 380px; bottom: -130px; right: -100px; animation-duration: 11s; animation-delay: 2s; }
        .blob-3 { width: 220px; height: 220px; bottom: 120px; left: 80px; animation-duration: 7s; animation-delay: 4s; }
        .blob-4 { width: 160px; height: 160px; top: 80px; right: 120px; animation-duration: 13s; animation-delay: 1s; background: rgba(255,255,255,0.04); }
        .blob-5 { width: 80px; height: 80px; top: 45%; left: 8%; animation-duration: 6s; animation-delay: 3s; background: rgba(255,255,255,0.12); }

        @@keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-22px); }
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

        .login-card {
            background: #ffffff;
            border-radius: 1.5rem;
            padding: 2.8rem 2.6rem;
            width: 100%;
            max-width: 430px;
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.28);
            position: relative;
            z-index: 10;
        }

        .brand-icon {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, #005c33, #00a854);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            box-shadow: 0 8px 24px rgba(0, 107, 60, 0.4);
        }
        .brand-icon i { font-size: 2.1rem; color: #fff; }

        .brand-label {
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 3px;
            color: #006B3C;
            text-transform: uppercase;
        }

        .card-title {
            font-size: 1.65rem;
            font-weight: 700;
            color: #111827;
            margin: 0.2rem 0 0.4rem;
        }

        .card-subtitle {
            font-size: 0.87rem;
            color: #6b7280;
            margin-bottom: 1.8rem;
            line-height: 1.45;
        }

        .form-label {
            font-size: 0.83rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.35rem;
        }

        .form-control {
            border-radius: 0.55rem;
            border: 1.5px solid #d1d5db;
            padding: 0.65rem 0.9rem;
            font-size: 0.92rem;
            color: #111827;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: #f9fafb;
        }
        .form-control::placeholder { color: #9ca3af; }
        .form-control:focus {
            border-color: #006B3C;
            box-shadow: 0 0 0 3px rgba(0, 107, 60, 0.14);
            background: #fff;
        }

        .input-group .form-control {
            border-right: none;
            border-radius: 0.55rem 0 0 0.55rem;
        }
        .input-group .form-control:focus { z-index: 3; }
        .input-group-text {
            background: #f9fafb;
            border: 1.5px solid #d1d5db;
            border-left: none;
            border-radius: 0 0.55rem 0.55rem 0;
            cursor: pointer;
            color: #6b7280;
            padding: 0 0.9rem;
            transition: color 0.15s;
        }
        .input-group-text:hover { color: #006B3C; }
        .input-group:focus-within .input-group-text { border-color: #006B3C; }

        .forgot-link {
            font-size: 0.82rem;
            color: #006B3C;
            text-decoration: none;
            font-weight: 500;
        }
        .forgot-link:hover { color: #004d2b; text-decoration: underline; }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, #006B3C, #00a854);
            border: none;
            border-radius: 0.55rem;
            padding: 0.75rem;
            font-size: 0.95rem;
            font-weight: 600;
            letter-spacing: 0.4px;
            color: #fff;
            transition: transform 0.15s, box-shadow 0.15s;
            box-shadow: 0 4px 18px rgba(0, 107, 60, 0.38);
        }
        .btn-login:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 8px 22px rgba(0, 107, 60, 0.48);
            color: #fff;
        }
        .btn-login:disabled { opacity: 0.72; color: #fff; }

        .divider { border: none; border-top: 1px solid #e5e7eb; margin: 1.3rem 0; }

        .register-text { font-size: 0.86rem; color: #6b7280; }
        .register-text a { color: #006B3C; font-weight: 600; text-decoration: none; }
        .register-text a:hover { text-decoration: underline; color: #004d2b; }

        .page-footer {
            position: fixed;
            bottom: 1.4rem;
            left: 50%;
            transform: translateX(-50%);
            color: rgba(255, 255, 255, 0.45);
            font-size: 0.75rem;
            z-index: 5;
            white-space: nowrap;
            pointer-events: none;
        }

        @@media (max-width: 480px) {
            .login-card { padding: 2rem 1.5rem; margin: 1rem; border-radius: 1rem; }
        }
    </style>
</head>
<body>

    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>

    <!-- Server-side message holders (read by JS → SweetAlert2) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <input type="hidden" id="swal-success" value="@TempData["SuccessMessage"]" />
    }
    @if (ViewData["ErrorMessage"] != null)
    {
        <input type="hidden" id="swal-error" value="@ViewData["ErrorMessage"]" />
    }

    <div class="login-card text-center">

        <div class="brand-icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <p class="brand-label mb-1">eCertify</p>
        <h1 class="card-title">Iniciar Sesión</h1>
        <p class="card-subtitle">Por favor introduzca sus credenciales para entrar a eCertify.</p>

        <form method="post" novalidate class="text-start">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">
                    Correo o usuario <span class="text-danger">*</span>
                </label>
                <input asp-for="Email" class="form-control" autocomplete="username"
                       placeholder="usuario@ejemplo.com" required />
            </div>

            <div class="mb-2">
                <label asp-for="Password" class="form-label">
                    Contraseña <span class="text-danger">*</span>
                </label>
                <div class="input-group">
                    <input asp-for="Password" type="password" id="passwordField" class="form-control"
                           autocomplete="current-password" placeholder="••••••••" required />
                    <span class="input-group-text" onclick="togglePassword()" title="Mostrar/ocultar contraseña">
                        <i class="bi bi-eye-slash" id="eyeIcon"></i>
                    </span>
                </div>
            </div>

            <div class="text-end mb-4">
                <a href="#" class="forgot-link">¿Olvidaste tu contraseña?</a>
            </div>

            <button type="submit" class="btn btn-login mb-3 d-flex align-items-center justify-content-center gap-2" id="btnEntrar">
                <span id="btnText">Entrar</span>
                <div id="spinner" class="spinner-border spinner-border-sm d-none" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
            </button>

            <hr class="divider" />

            <p class="register-text text-center mb-0">
                ¿No tienes una cuenta? <a href="/Register">Regístrate</a>
            </p>
        </form>

    </div>

    <p class="page-footer">© 2025 eCertify — Todos los derechos reservados</p>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        window.addEventListener("DOMContentLoaded", () => {
            document.querySelector("input[name='Email']")?.focus();

            // Server-side alerts via SweetAlert2
            const successEl = document.getElementById('swal-success');
            if (successEl) {
                Swal.fire({
                    icon: 'success',
                    title: '¡Éxito!',
                    text: successEl.value,
                    confirmButtonColor: '#006B3C'
                });
            }

            const errorEl = document.getElementById('swal-error');
            if (errorEl) {
                Swal.fire({
                    icon: 'error',
                    title: 'Acceso denegado',
                    text: errorEl.value,
                    confirmButtonColor: '#006B3C',
                    confirmButtonText: 'Intentar de nuevo'
                });
            }

            // Form submit validation
            const form    = document.querySelector("form");
            const btn     = document.getElementById("btnEntrar");
            const spinner = document.getElementById("spinner");
            const btnText = document.getElementById("btnText");

            form?.addEventListener("submit", (e) => {
                const email    = form.querySelector("input[name='Email']").value.trim();
                const password = form.querySelector("input[name='Password']").value.trim();

                if (!email || !password) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Campos requeridos',
                        text: 'Por favor, complete todos los campos obligatorios.',
                        confirmButtonColor: '#006B3C'
                    });
                    return;
                }

                spinner.classList.remove("d-none");
                btnText.textContent = "Entrando...";
                btn.disabled = true;
            });
        });

        function togglePassword() {
            const field = document.getElementById("passwordField");
            const icon  = document.getElementById("eyeIcon");
            if (field.type === "password") {
                field.type = "text";
                icon.className = "bi bi-eye";
            } else {
                field.type = "password";
                icon.className = "bi bi-eye-slash";
            }
        }
    </script>

</body>
</html>
