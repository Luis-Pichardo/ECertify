@page
@model eCertify.Pages.Pagos.PagoModel
@{
    Layout = null;
    ViewData["Title"] = "Pago con PayPal";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Pagar Certificación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- SDK de PayPal -->
    <script src="https://www.paypal.com/sdk/js?client-id=AdyvpEVfyNzOc54dVansPxjKoCg_rxNNqLi7DUPAZhaGxXtBSlWziLL-QumHB2S-az4hq6nqghEwSXZt&currency=USD"></script>
</head>
<body class="bg-light">

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow-sm" style="max-width: 400px; width: 100%;">
        <h2 class="text-center mb-3">Pago de Certificación</h2>
        <p class="text-center mb-4">
            Selecciona la cantidad de accesos que deseas adquirir.
        </p>

        <!-- Selección de cantidad -->
        <div class="mb-3">
            <label for="tokenQuantity" class="form-label fw-bold">Cantidad de accesos</label>
            <input type="number" id="tokenQuantity" class="form-control" value="1" min="1" />
        </div>

        <p class="text-center mb-4">
            Total a pagar: <strong id="totalAmount">$10.00 USD</strong>
        </p>

        <!-- Contenedor del botón de PayPal -->
        <div id="paypal-button-container"></div>

            <!-- Formulario oculto que recibe los datos del pago -->
            <form method="post" asp-page-handler="ProcesarPago" id="formPago">
                <input type="hidden" asp-for="Pago.PayPalOrderId" />
                <input type="hidden" asp-for="Pago.TransactionId" />
                <input type="hidden" asp-for="Pago.PayerName" />
                <input type="hidden" asp-for="Pago.PayerEmail" />
                <input type="hidden" asp-for="Pago.Amount" />
                <input type="hidden" asp-for="Pago.Currency" />
                <input type="hidden" asp-for="Pago.Quantity" />
            </form>

    </div>
</div>

<script>
    const pricePerToken = 10;

    document.getElementById("tokenQuantity").addEventListener("input", function () {
        const qty = parseInt(this.value) || 1;
        const total = (qty * pricePerToken).toFixed(2);
        document.getElementById("totalAmount").innerText = `$${total} USD`;
    });

    paypal.Buttons({
        funding: {
            disallowed: [paypal.FUNDING.CARD] // Desactiva la opción de tarjeta
        },
        createOrder: function (data, actions) {
            const qty = document.getElementById("tokenQuantity").value;
            const total = (qty * pricePerToken).toFixed(2);

            return actions.order.create({
                purchase_units: [{
                    description: `Compra de ${qty} AccessToken(s)`,
                    amount: { value: total }
                }]
            });
        },
            onApprove: function (data, actions) {
                return actions.order.capture().then(function (details) {
                    const qty = document.getElementById("tokenQuantity").value;

                    // Llenar los inputs ocultos
                    document.querySelector("[name='Pago.PayPalOrderId']").value = data.orderID;
                    document.querySelector("[name='Pago.TransactionId']").value = details.id;
                    document.querySelector("[name='Pago.PayerName']").value =
                        `${details.payer.name.given_name} ${details.payer.name.surname}`;
                    document.querySelector("[name='Pago.PayerEmail']").value = details.payer.email_address;
                    document.querySelector("[name='Pago.Amount']").value = details.purchase_units[0].amount.value;
                    document.querySelector("[name='Pago.Currency']").value = details.purchase_units[0].amount.currency_code;
                    document.querySelector("[name='Pago.Quantity']").value = qty;

                    // Enviar el formulario
                    document.getElementById("formPago").submit();
                });
            }

    }).render('#paypal-button-container');
</script>

</body>
</html>
