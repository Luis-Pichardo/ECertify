@* Pages/Shared/_Navbar.cshtml *@
@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor

@{
    var currentUser = HttpContextAccessor.HttpContext?.User;
    var userName    = currentUser?.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var userSurname = currentUser?.FindFirst("Apellido")?.Value ?? "";
    var companyName = currentUser?.FindFirst("RazonSocial")?.Value ?? "";
    var currentPath = HttpContextAccessor.HttpContext?.Request.Path.Value?.ToLower() ?? "";
}

<nav class="top-nav" id="appTopNav">

    <!-- Brand -->
    <a href="/Home" class="top-nav__brand">
        <i class="bi bi-shield-lock-fill"></i>
        <span>eCertify</span>
    </a>

    <!-- Right controls -->
    <div class="top-nav__controls">

        <!-- Company switcher -->
        @if (!string.IsNullOrWhiteSpace(companyName))
        {
            <div class="dropdown">
                <button class="tnav-company" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-building-fill"></i>
                    <span class="tnav-company__name">@companyName</span>
                    <i class="bi bi-chevron-down tnav-company__caret"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end tnav-dropdown">
                    <li>
                        <span class="tnav-dropdown__header">
                            <i class="bi bi-building-fill me-1"></i>@companyName
                        </span>
                    </li>
                    <li><hr class="dropdown-divider my-1" /></li>
                    <li>
                        <a class="tnav-dropdown__item" href="/CompanySelect">
                            <i class="bi bi-arrow-repeat"></i>
                            Cambiar empresa
                        </a>
                    </li>
                </ul>
            </div>
            <div class="tnav-divider"></div>
        }

        <!-- User info -->
        @if (!string.IsNullOrWhiteSpace(userName))
        {
            <div class="tnav-user">
                <div class="tnav-user__avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <span class="tnav-user__name d-none d-md-inline">@userName @userSurname</span>
            </div>
            <div class="tnav-divider d-none d-md-block"></div>
        }

        <!-- Logout -->
        <button class="tnav-logout" type="button"
                onclick="document.getElementById('logoutForm').submit();"
                title="Cerrar sesión">
            <i class="bi bi-box-arrow-right"></i>
            <span class="d-none d-sm-inline">Salir</span>
        </button>
        <form id="logoutForm" method="post" asp-page="/Logout" style="display:none;"></form>

    </div>
</nav>
